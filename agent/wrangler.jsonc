{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lauki-connect-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-24",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "PROFILE_SEARCH_AGENT",
        "class_name": "ProfileSearchAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ProfileSearchAgent"]
    }
  ],
  "vars": {
    "CLOUDFLARE_AI_MODEL": "@cf/zai-org/glm-4.7-flash",
    "BASE_RPC_URL": "https://mainnet.base.org",
    "GITHUB_API_TOKEN": "",
    "NEYNAR_API_KEY": "",
    "TALENT_API_KEY": ""
  }
}
