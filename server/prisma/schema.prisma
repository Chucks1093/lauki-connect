generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ConnectRequest {
  id          String           @id @default(cuid())
  goal        String
  requester   String?
  createdAt   DateTime         @default(now())
  matches     CandidateMatch[]
  feedback    FeedbackEvent[]
}

model CandidateMatch {
  id               String         @id @default(cuid())
  connectRequestId String
  name             String
  role             String
  company          String
  location         String
  score            Int
  reason           String
  introDraft       String
  createdAt        DateTime       @default(now())
  connectRequest   ConnectRequest @relation(fields: [connectRequestId], references: [id], onDelete: Cascade)
}

model FeedbackEvent {
  id               String         @id @default(cuid())
  connectRequestId String
  candidateMatchId String?
  sentiment        String
  note             String?
  createdAt        DateTime       @default(now())
  connectRequest   ConnectRequest @relation(fields: [connectRequestId], references: [id], onDelete: Cascade)
}
