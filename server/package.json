{
  "name": "lauki-connect-server",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "type": "module",
  "prisma": {
    "schema": "./prisma/schema"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "prisma:generate": "prisma generate --schema ./prisma/schema",
    "prisma:push": "prisma db push --schema ./prisma/schema",
    "validate-api": "tspec validate"
  },
  "dependencies": {
    "@prisma/client": "^6.19.1",
    "chalk": "^5.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "tspec": "^0.1.116",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.0.15",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "prisma": "^6.19.1",
    "tsx": "^4.20.3",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1"
  }
}
